{
  "expo": {
    "name": "The System",
    "slug": "the-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050508",
    "jsEngine": "hermes",
    "assetBundlePatterns": [],
    "android": {
      "package": "com.thesystem.tracker",
      "backgroundColor": "#050508",
      "permissions": ["android.permission.ACTIVITY_RECOGNITION"],
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-sensors",
        { "motionPermission": "The System tracks your steps to level up Endurance." }
      ]
    ]
  }
}
